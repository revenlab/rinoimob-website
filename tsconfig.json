{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "baseUrl": ".",
    "paths": {
      "#app": ["./.nuxt"],
      "#build": ["./.nuxt"],
      "#head": ["./.nuxt/head"],
      "~": ["."],
      "@": ["./src"]
    }
  },
  "include": ["./**/*.ts", "./**/*.vue", ".nuxt/nuxt.d.ts"]
}
